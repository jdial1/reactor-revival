{
  "name": "reactor-revival",
  "version": "1.0.0",
  "description": "Reactor Revival",
  "type": "module",
  "main": "public/index.html",
  "debug": false,
  "scripts": {
    "test": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192 --expose-gc\" vitest --run -c config/vitest.config.mjs",
    "test:performance": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192 --expose-gc\" CI=true vitest run tests/core/performance.test.js -c config/vitest.config.mjs --testTimeout=120000 --hookTimeout=60000",
    "test:ci": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192 --expose-gc\" vitest --run -c config/vitest.config.mjs",
    "test:deploy": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" vitest run -c config/vitest.config.mjs --exclude \"tests/ui/**|tests/core/performance.test.js|tests/core/clipboard.test.js|tests/core/pasteModal.test.js\"",
    "dev": "node scripts/serve-with-coop.js",
    "setup": "npm run generate-version && npm run copy-libs && npm run build:sw",
    "generate-version": "node scripts/generate-version.js",
    "copy-libs": "node scripts/copy-libs.js",
    "build:sw": "workbox injectManifest config/workbox-config.cjs",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint . -c config/eslint.config.js --format @microsoft/eslint-formatter-sarif --output-file eslint-results.sarif",
    "lint:css": "stylelint \"public/**/*.css\" \"public/**/*.html\" \"public/**/*.js\" --config config/.stylelintrc.json --fix",
    "check-pwa-root-files": "node scripts/check-pwa-root-files.js",
    "remove-console-logs": "node scripts/remove-console-logs.js",
    "compress-images": "node scripts/compress-images.js",
    "generate-bg-count": "node scripts/generate-bg-count.js",
    "postinstall": "npm run copy-libs"
  },
  "keywords": [],
  "x-build": {
    "sw": "public/sw.js is generated from src-sw.js by npm run build:sw. Do not edit public/sw.js manually."
  },
  "author": "Justin Dial",
  "license": "ISC",
  "dependencies": {
    "@tanstack/query-core": "^5.90.20",
    "break_infinity.js": "^2.2.0",
    "derive-valtio": "^0.2.0",
    "express": "^4.18.2",
    "idb-keyval": "^6.2.2",
    "lit-html": "^3.3.2",
    "superjson": "^2.2.6",
    "valtio": "^2.3.0",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@stylistic/stylelint-plugin": "^3.1.3",
    "@zip.js/zip.js": "^2.7.62",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.0",
    "eslint": "^9.32.0",
    "glob": "^11.0.3",
    "happy-dom": "^20.0.11",
    "jsdom": "^24.1.0",
    "pako": "^2.1.0",
    "postcss": "^8.5.6",
    "postcss-combine-duplicated-selectors": "^10.0.3",
    "postcss-html": "^1.8.1",
    "sharp": "^0.34.5",
    "stylelint": "^16.8.1",
    "stylelint-color-format": "^1.1.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-declaration-block-no-ignored-properties": "^2.8.0",
    "stylelint-declaration-strict-value": "^1.10.11",
    "stylelint-gamut": "^1.3.4",
    "stylelint-high-performance-animation": "^1.11.0",
    "stylelint-media-use-custom-media": "^4.0.0",
    "stylelint-no-browser-hacks": "^2.0.0",
    "stylelint-no-indistinguishable-colors": "^2.3.1",
    "stylelint-no-restricted-syntax": "^2.2.1",
    "stylelint-no-unresolved-module": "^2.4.0",
    "stylelint-no-unsupported-browser-features": "^8.0.4",
    "stylelint-order": "^7.0.0",
    "stylelint-plugin-defensive-css": "^1.0.4",
    "stylelint-plugin-logical-css": "^1.2.3",
    "stylelint-plugin-use-baseline": "^0.9.1",
    "stylelint-react-native": "^2.7.0",
    "stylelint-scales": "^5.0.0",
    "stylelint-scss": "^6.12.1",
    "stylelint-selector-bem-pattern": "^4.0.1",
    "stylelint-stylus": "^1.0.0",
    "stylelint-use-nesting": "^6.0.0",
    "stylelint-value-no-unknown-custom-properties": "^6.0.1",
    "vitest": "^1.6.1",
    "workbox-cli": "^7.3.0"
  },
  "overrides": {
    "braces": ">=3.0.3",
    "micromatch": ">=4.0.8"
  }
}
