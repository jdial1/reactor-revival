{
  "name": "reactor-revival",
  "version": "1.0.0",
  "description": "Reactor Revival",
  "type": "module",
  "main": "public/index.html",
  "debug": false,
  "scripts": {
    "test": "node scripts/test-runner.js",
    "audit:debt": "python scripts/technical-debt-audit.py --profile full",
    "audit:debt:public": "python scripts/technical-debt-audit.py --profile public",
    "check:imports": "eslint public/src -c config/eslint.config.js --quiet",
    "check:test-patterns": "node scripts/check-expect-tonum.js",
    "test:performance": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192 --expose-gc\" CI=true vitest run tests/core/engine/performance.test.js -c config/vitest.config.mjs --testTimeout=120000 --hookTimeout=60000",
    "test:ci": "node scripts/test-runner.js",
    "test:deploy": "cross-env REACTOR_TEST_ENGINE=core NODE_OPTIONS=\"--max-old-space-size=4096\" vitest run -c config/vitest.config.mjs --exclude \"tests/ui/**|tests/core/engine/performance.test.js|tests/core/engine/clipboard.test.js|tests/core/engine/pasteModal.test.js\"",
    "test:deploy:core": "npm run test:deploy",
    "dev": "node scripts/serve-with-coop.js",
    "setup": "node scripts/setup-runner.js",
    "generate-metadata": "node scripts/generate-metadata.js",
    "generate-changelog": "node scripts/generate-changelog.js",
    "bundle:static-data": "node scripts/generate-revival-manifest.mjs && node scripts/bundle-static-data.mjs",
    "generate:revival-manifest": "node scripts/generate-revival-manifest.mjs",
    "copy-libs": "node scripts/copy-libs.js",
    "css:dedupe": "node scripts/css-dedupe.js",
    "css:consolidate": "node scripts/consolidate-css-traits.mjs",
    "build:css": "node scripts/bundle-css.mjs",
    "build:sw": "workbox injectManifest config/workbox-config.cjs",
    "lint": "node scripts/lint-runner.js",
    "lint:js": "eslint . -c config/eslint.config.js --cache --cache-location node_modules/.cache/eslint --format @microsoft/eslint-formatter-sarif --output-file eslint-results.sarif",
    "lint:css": "stylelint \"public/**/*.css\" \"public/**/*.html\" \"public/**/*.js\" --config config/.stylelintrc.json --ignore-path .stylelintignore --fix",
    "check-pwa-root-files": "node scripts/pwa-check.js",
    "remove-console-logs": "node scripts/remove-console-logs.js",
    "compress-images": "node scripts/compress-images.js",
    "build:atlas": "node scripts/build-sprite-atlas.js",
    "postinstall": "npm run copy-libs",
    "ui:console-audit": "node scripts/ui-console-audit.js",
    "ui:console-audit:headed": "cross-env HEADED=1 node scripts/ui-console-audit.js",
    "ui:console-audit:deploy": "cross-env AUDIT_FAIL_ON=pageerror,critical.startup node scripts/ui-console-audit.js",
    "ui:screenshots": "node scripts/ui-screenshots.js",
    "ui:screenshots:headed": "cross-env HEADED=1 node scripts/ui-screenshots.js",
    "ui:screenshots:deploy": "node scripts/ui-screenshots.js",
    "ui:screenshots:baseline": "cross-env UPDATE_SCREENSHOT_BASELINE=1 node scripts/ui-screenshots.js",
    "ui:screenshots:backup": "node scripts/ui-screenshot-backup.js",
    "ui:screenshots:compare": "node scripts/ui-screenshot-compare.js",
    "ui:screenshots:compare:headed": "cross-env HEADED=1 node scripts/ui-screenshot-compare.js",
    "ui:production:reference": "node scripts/ui-production-reference.js",
    "ui:production:align": "node scripts/ui-production-align.js",
    "ui:production:sync": "node scripts/ui-production-reference.js && node scripts/ui-production-align.js",
    "ui:production:screenshots:compare": "node scripts/ui-production-screenshot-compare.js",
    "ui:prod-fixes": "node scripts/ui-prod-fixes.js",
    "test:e2e": "cross-env E2E_RESOLUTION= playwright test -c config/playwright.config.mjs",
    "test:e2e:ui": "cross-env E2E_RESOLUTION= playwright test -c config/playwright.config.mjs --ui",
    "test:e2e:resolution": "playwright test -c config/playwright.config.mjs"
  },
  "keywords": [],
  "x-build": {
    "sw": "public/sw.js is generated from src-sw.js by npm run build:sw. Do not edit public/sw.js manually."
  },
  "author": "Justin Dial",
  "license": "ISC",
  "dependencies": {
    "@tanstack/query-core": "^5.90.20",
    "break_infinity.js": "^2.2.0",
    "derive-valtio": "^0.2.0",
    "express": "^4.18.2",
    "idb-keyval": "^6.2.2",
    "lit-html": "^3.3.2",
    "reactor-core-lib": "^1.2.9",
    "superjson": "^2.2.6",
    "valtio": "^2.3.0",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/press-start-2p": "^5.2.7",
    "@fontsource/share-tech-mono": "^5.2.7",
    "@fontsource/vt323": "^5.2.7",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@playwright/test": "^1.61.1",
    "@stylistic/stylelint-plugin": "^3.1.3",
    "@zip.js/zip.js": "^2.7.62",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.0",
    "eslint": "^9.32.0",
    "eslint-import-resolver-node": "^0.3.10",
    "eslint-plugin-import": "^2.32.0",
    "glob": "^11.0.3",
    "happy-dom": "^20.0.11",
    "jsdom": "^24.1.0",
    "pako": "^2.1.0",
    "postcss": "^8.5.6",
    "postcss-combine-duplicated-selectors": "^10.0.3",
    "postcss-html": "^1.8.1",
    "puppeteer": "^24.4.0",
    "sharp": "^0.34.5",
    "stylelint": "^16.8.1",
    "stylelint-color-format": "^1.1.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-declaration-block-no-ignored-properties": "^2.8.0",
    "stylelint-declaration-strict-value": "^1.10.11",
    "stylelint-gamut": "^1.3.4",
    "stylelint-high-performance-animation": "^1.11.0",
    "stylelint-media-use-custom-media": "^4.0.0",
    "stylelint-no-browser-hacks": "^2.0.0",
    "stylelint-no-indistinguishable-colors": "^2.3.1",
    "stylelint-no-restricted-syntax": "^2.2.1",
    "stylelint-no-unresolved-module": "^2.4.0",
    "stylelint-no-unsupported-browser-features": "^8.0.4",
    "stylelint-order": "^7.0.0",
    "stylelint-plugin-defensive-css": "^1.0.4",
    "stylelint-plugin-logical-css": "^1.2.3",
    "stylelint-plugin-use-baseline": "^0.9.1",
    "stylelint-react-native": "^2.7.0",
    "stylelint-scales": "^5.0.0",
    "stylelint-scss": "^6.12.1",
    "stylelint-selector-bem-pattern": "^4.0.1",
    "stylelint-stylus": "^1.0.0",
    "stylelint-use-nesting": "^6.0.0",
    "stylelint-value-no-unknown-custom-properties": "^6.0.1",
    "vitest": "^1.6.1",
    "workbox-cli": "^7.3.0"
  },
  "overrides": {
    "braces": ">=3.0.3",
    "micromatch": ">=4.0.8"
  }
}
